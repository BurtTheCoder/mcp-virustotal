# VirusTotal API key (direct mode)
# Obtain yours at https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Override the VirusTotal API base URL (optional)
# Set this to route requests through a proxy / gateway endpoint.
# When unset, requests go directly to https://www.virustotal.com/api/v3
VIRUSTOTAL_BASE_URL=

# Bearer token sent as Authorization header when using a proxy base URL (optional)
# Required only when VIRUSTOTAL_BASE_URL points to an authenticated proxy.
VIRUSTOTAL_AUTH_TOKEN=

# Request timeout in milliseconds (default: 30000)
VIRUSTOTAL_TIMEOUT=30000

# --- HTTP transport settings (only used when MCP_TRANSPORT=http) ---
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=localhost
